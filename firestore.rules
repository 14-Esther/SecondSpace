rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is this a Firebase-authenticated admin?
    function isFirebaseAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users ──────────────────────────────────
    match /users/{userId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (request.auth.uid == userId || isFirebaseAdmin());
      // Allow delete if: Firebase admin OR no auth at all
      // (no-auth = hardcoded admin who has no Firebase session)
      allow delete: if isFirebaseAdmin() || request.auth == null;
    }

    // ── Items ──────────────────────────────────
    match /items/{itemId} {
      allow read:   if true; // public read is fine for a marketplace
      allow create: if request.auth != null;
      allow update, delete: if isFirebaseAdmin() ||
        request.auth == null ||
        (request.auth != null && resource.data.sellerId == request.auth.uid);
    }

    // ── Interests ──────────────────────────────
    match /interests/{intId} {
      allow read: if isFirebaseAdmin() ||
        request.auth == null ||
        (request.auth != null && (
          resource.data.sellerId == request.auth.uid ||
          resource.data.buyerId  == request.auth.uid
        ));
      allow create: if request.auth != null;
      allow delete: if isFirebaseAdmin() || request.auth == null;
    }

  }
}
